# GMail SMTP Credentials
EMAIL=your_email@gmail.com
PASSWORD=your_gmail_app_password

# Template configuration
# Choices: dynamic, static, api
# - dynamic: randomly generated text messages with greetings/wishes/closings
# - static: randomly loads from local letter_templates (letter_1.txt, etc.)
# - api: calls a free public API to fetch a daily piece of advice/quote
TEMPLATE_SOURCE=dynamic
